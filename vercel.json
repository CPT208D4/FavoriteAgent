{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/",
      "destination": "/FavoriteAgent-frontend-pockety/home.html"
    },
    {
      "source": "/(.*)",
      "destination": "/FavoriteAgent-frontend-pockety/$1"
    }
  ]
}

